# Vite: apenas variáveis públicas (prefixo VITE_)
# NÃO coloque a API key da Evolution em VITE_ — use secrets das Edge Functions no Supabase.

# Opcional: URL pública da Evolution (se quiser health-check no cliente; a Edge Function usa EVOLUTION_BASE_URL nos secrets)
# VITE_EVOLUTION_BASE_URL=https://sua-evolution.exemplo.com

# Supabase (já usado pelo projeto — exemplo)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Edge Functions do Supabase: configurar no painel (Project Settings > Edge Functions > Secrets):
# EVOLUTION_BASE_URL=https://sua-evolution.exemplo.com
# EVOLUTION_API_KEY=sua-apikey-global-da-evolution
# EVOLUTION_INSTANCE_NAME=nome-instancia   (opcional se usar só app_c009c0e4f1_integration_settings)
# SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY são injetados automaticamente nas functions

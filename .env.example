# Vite: apenas variáveis públicas (prefixo VITE_)
# NÃO coloque a API key da Evolution em VITE_ — use secrets das Edge Functions no Supabase.

# Opcional: URL pública da Evolution (se quiser health-check no cliente; a Edge Function usa EVOLUTION_BASE_URL nos secrets)
# VITE_EVOLUTION_BASE_URL=https://sua-evolution.exemplo.com

# Supabase (já usado pelo projeto — exemplo)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Edge Functions do Supabase: configurar no painel (Project Settings > Edge Functions > Secrets):
# EVOLUTION_BASE_URL=https://sua-evolution.exemplo.com
# EVOLUTION_API_KEY=sua-apikey-global-da-evolution
# EVOLUTION_INSTANCE_NAME=nome-instancia   (opcional se usar só app_c009c0e4f1_integration_settings)
# SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY são injetados automaticamente nas functions

# SharePoint / Microsoft Graph (Edge Function sharepoint-treinamentos)
# Opção A — secrets no painel Supabase (Edge Function Secrets)
# Opção B — node scripts/seed-sharepoint-settings.mjs (salva em integration_settings)
# MICROSOFT_TENANT_ID=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# SHAREPOINT_SITE_ID=host.sharepoint.com,{siteCollectionId},{siteId}   # CONTROLADORIAJURDICA (treinamentos)
# SHAREPOINT_TREINAMENTOS_LIST_ID=
# SHAREPOINT_BP_SITE_ID=bpplaw2.sharepoint.com,6b17bdcc-ac8f-4ceb-b85c-0003edaac18e,22808632-e691-4d75-a258-ad29be94ee25
# SHAREPOINT_USUARIOS_LIST_ID=f7d4fe37-a3fe-4487-b70e-6949311bfa23
#
# Exportar LookupIds:
#   node scripts/export-sharepoint-lookup-ids.mjs usuarios          # lista USUARIOS (site BP)
#   node scripts/export-sharepoint-lookup-ids.mjs controladoria --rebuild
#   node scripts/export-sharepoint-lookup-ids.mjs compare
#
# Permissão Azure AD necessária para resolver Responsável por e-mail (mesmo app do n8n):
# User.Read.All (Application) + admin consent
# Depois: node scripts/sync-graph-user-map.mjs
# LookupId SharePoint (opcional — webhook n8n com ensureUser delegado):
# SHAREPOINT_ENSURE_USER_WEBHOOK_URL=https://seu-n8n/webhook/sharepoint-ensure-user
